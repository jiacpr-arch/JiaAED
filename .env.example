# ============================================================================
# JiaAED — environment variables (คัดลอกเป็น .env.local สำหรับ dev)
# ตัวที่ mark [จำเป็น] ถ้าไม่ตั้ง ฟีเจอร์หลักจะไม่ทำงาน
# ============================================================================

# --- Site ---
# โดเมนหลักของเว็บ (ใช้ใน metadata, sitemap, feed, cron health-check)
NEXT_PUBLIC_SITE_URL=https://www.jiaaed.com

# --- Supabase [จำเป็น] ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth / secrets [จำเป็น] ---
# ใช้ยืนยัน cron จาก Vercel — ถ้าไม่ตั้ง cron ทุกตัวจะถูกปฏิเสธ (fail-closed)
CRON_SECRET=
# token เดียวสำหรับหน้า /admin/*
ADMIN_TOKEN=
# bearer ของ endpoint ภายใน (google-ads conversion/report)
AED_INTERNAL_API_KEY=
# salt สำหรับ hash IP ใน lead/analytics (ตั้งครั้งเดียว อย่าเปลี่ยน — hash จะเพี้ยน)
LEAD_IP_SALT=

# --- Anthropic (web chat, LINE bot, cron ที่ใช้ AI) [จำเป็น] ---
ANTHROPIC_API_KEY=

# --- LINE Official Account [จำเป็น] ---
AED_LINE_CHANNEL_SECRET=
AED_LINE_CHANNEL_ACCESS_TOKEN=
# LINE user id เจ้าของ (รับแจ้งเตือน lead/digest)
AED_OWNER_LINE_USER_ID=
# แอดมินเพิ่มเติม คั่นด้วย comma (ไม่บังคับ)
AED_ADMIN_LINE_USER_IDS=

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CONVERSION_ACTION_ID=

# --- Meta (Pixel + Conversions API) ---
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=
# ใส่เฉพาะตอนทดสอบ event ใน Meta Events Manager
META_TEST_EVENT_CODE=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# --- FlowAccount (ออกใบเสนอราคาจาก LINE bot) ---
FLOWACCOUNT_TOKEN_URL=
FLOWACCOUNT_BASE_URL=
FLOWACCOUNT_CLIENT_ID=
FLOWACCOUNT_CLIENT_SECRET=

# --- GitHub (cron auto-optimize / article-gap เปิด PR) ---
GITHUB_TOKEN=
# ค่า default ในโค้ดคือ jiacpr-arch/JiaAED
GITHUB_REPO=

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

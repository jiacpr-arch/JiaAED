# ─────────────────────────────────────────────────────────────────────────────
# JiaAED — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy/paste each value into Vercel Dashboard → Settings → Environment Variables
# Set scope to "Production" (and "Preview" if you want preview deploys to work).
# ─────────────────────────────────────────────────────────────────────────────


# ═══════ REQUIRED — ระบบจะพังถ้าไม่ตั้ง ═════════════════════════════════════════

# Anthropic Claude API (AI orchestrator)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase (DB + RLS service role)
# https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# LINE Messaging API (chatbot)
# https://developers.line.biz/console → Channel → Messaging API
AED_LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AED_LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Owner's LINE userId — ดูจาก follow event log ตอนกด "เพิ่มเพื่อน" ครั้งแรก
AED_OWNER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (payments)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# https://dashboard.stripe.com/webhooks → endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# FlowAccount (quotation + receipt)
# https://flowaccount.com/developer/my-apps
FLOWACCOUNT_CLIENT_ID=xxxxxxxxxxxxxxxx
FLOWACCOUNT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Public app URL (for Stripe payment-link redirect)
NEXT_PUBLIC_APP_URL=https://jiaaed.vercel.app

# Public LINE OA URL (for landing CTAs / fallback)
NEXT_PUBLIC_LINE_OA_URL=https://line.me/R/ti/p/@273fzpzs


# ═══════ REQUIRED — Phase 2 cron + Phase 3 admin ═════════════════════════════

# Cron endpoint protection (Vercel Cron sends Authorization: Bearer $CRON_SECRET)
# Generate: openssl rand -hex 32
CRON_SECRET=REPLACE_WITH_RANDOM_HEX_32

# Admin dashboard login
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_12_CHARS
# HMAC secret used to sign the admin session cookie
# Generate: openssl rand -hex 32
ADMIN_COOKIE_SECRET=REPLACE_WITH_RANDOM_HEX_32


# ═══════ OPTIONAL — Phase 5 ad tracking (ถ้าไม่ตั้ง pixel จะไม่โหลด) ═════════════

# Meta Pixel (client-side fbq)
# https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# Meta Conversion API (server-side, for ROAS attribution that survives ad-blockers)
# Events Manager → Settings → Conversion API → Generate access token
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: while testing, get from Events Manager → Test Events tab.
# DELETE this var when going live or events will only show in test view.
# META_CAPI_TEST_EVENT_CODE=TEST12345

# Google Tag (gtag.js) — GA4 "G-XXX" or Google Ads "AW-XXX"
NEXT_PUBLIC_GOOGLE_TAG_ID=G-XXXXXXXXXX


# ═══════ OPTIONAL — Defaults already set in code, only override if needed ═════

# FlowAccount API base
# Production: https://openapi.flowaccount.com/v1
# Sandbox/test: https://openapi.flowaccount.com/test
# FLOWACCOUNT_BASE_URL=https://openapi.flowaccount.com/v1
# FLOWACCOUNT_TOKEN_URL=https://openapi.flowaccount.com/token

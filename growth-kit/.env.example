# ── Supabase (data store) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic / Claude (AI digest analysis) ───────────────────────────
ANTHROPIC_API_KEY=

# ── LINE Messaging API (one channel; both vars or skip both) ──────────
GK_LINE_CHANNEL_ACCESS_TOKEN=
GK_LINE_OWNER_ID=

# ── Telegram (one channel; both vars or skip both) ────────────────────
GK_TELEGRAM_BOT_TOKEN=
GK_TELEGRAM_CHAT_ID=

# ── Cron auth (optional but recommended on Vercel) ────────────────────
# If set, cron routes require `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=
